# ─── Notes editor ───────────────────────────────────────────
# Vercel Postgres (Neon). Provisioned automatically when you create a
# Postgres store in the Vercel dashboard; pull locally with:
#   vercel env pull .env.local
DATABASE_URL=
# (POSTGRES_URL also works if that's what Vercel injected.)

# NextAuth (Auth.js). Generate a secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# GitHub OAuth app (github.com/settings/developers → New OAuth App).
# Authorization callback URL:
#   http://localhost:3000/api/auth/callback/github   (local)
#   https://www.mtosity.com/api/auth/callback/github (prod)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ─── Existing ───────────────────────────────────────────────
# Vercel Blob (already used for photography + note image uploads)
BLOB_READ_WRITE_TOKEN=
